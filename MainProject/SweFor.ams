	Procedure PutAgeClasses {
		Body: {
			OutputFileResults := "AgeClasses.txt" ;
			ResultFile.PageWidth := 600 ;
			PUT ResultFile ;
			
			PUT "Ageclass" , @10; PUT "Area":>10, @20; PUT "m3PerHa":>10; PUT / ;
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 3, Area(i) * Areascale * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "0" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 3, m3Vol(i,j,1) * Area(i) * Areascale * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ; 
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 11 and Age(i,j,1) >= 3, Area(i) * Areascale * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "3" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 11 and Age(i,j,1) >= 3, m3Vol(i,j,1) * Area(i) * Areascale * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ; 
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 21 and Age(i,j,1) >= 11, Area(i) * Areascale * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "11" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 21 and Age(i,j,1) >= 11, m3Vol(i,j,1) * Area(i) * Areascale * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 31 and Age(i,j,1) >= 21, Area(i) * Areascale * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "21" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 31 and Age(i,j,1) >= 21, m3Vol(i,j,1) * Area(i) * Areascale * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 41 and Age(i,j,1) >= 31, Area(i) * Areascale * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "31" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 41 and Age(i,j,1) >= 31, m3Vol(i,j,1) * Area(i) * Areascale * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 61 and Age(i,j,1) >= 41, Area(i) * Areascale * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "41" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 61 and Age(i,j,1) >= 41, m3Vol(i,j,1) * Area(i) * Areascale * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 81 and Age(i,j,1) >= 61, Area(i) * Areascale * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "61" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 81 and Age(i,j,1) >= 61, m3Vol(i,j,1) * Area(i) * Areascale * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 101 and Age(i,j,1) >= 81, Area(i) * Areascale * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "81" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 101 and Age(i,j,1) >= 81, m3Vol(i,j,1) * Area(i) * Areascale * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 121 and Age(i,j,1) >= 101, Area(i) * Areascale * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "101" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 121 and Age(i,j,1) >= 101, m3Vol(i,j,1) * Area(i) * Areascale * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 141 and Age(i,j,1) >= 121, Area(i) * Areascale * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "121" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 141 and Age(i,j,1) >= 121, m3Vol(i,j,1) * Area(i) * Areascale * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) >= 141, Area(i) * Areascale * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "141+" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) >= 141, m3Vol(i,j,1) * Area(i) * Areascale * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ; 
			
			PUT sum[ (i,j), Area(i) * Areascale * x(i,j) ] * 1.e-6 : >10:2; PUT / ; 
			PUT sum[ (i,j), m3Vol(i,j,1) * Area(i) * Areascale * x(i,j) ] * 1.e-6 : >10:2; PUT / ; 
			
			putclose ResultFile ;
		}
	}
	Procedure PutBirchSawMillAnalysisData {
		Body: {
			OutputFileResults := "BirchSawMillData.txt" ;
			ResultFile.PageWidth := 600 ;
			PUT ResultFile ;
			
			for fa | FacitlityType(fa) = "sawmbe" do
				put fa: >10:2;
				put NetOutputAtFacility('Sawnbe',fa,1): >10:0 ;
				put sum[ ia | KmPlotToLoc(ia,CurrFacInLoc(fa)) < 100, 
					max( (j) | j in xToRun(ia), PlotOutput('BerTim',ia,j,1) ) * Area(ia) * AreaScale ]*0.2: >10:0;
				put sum[ ia | KmPlotToLoc(ia,CurrFacInLoc(fa)) < 200, 
					max( (j) | j in xToRun(ia), PlotOutput('BerTim',ia,j,1) ) * Area(ia) * AreaScale ]*0.2: >10:0;
				put sum[ ia | KmPlotToLoc(ia,CurrFacInLoc(fa)) < 300, 
					max( (j) | j in xToRun(ia), PlotOutput('BerTim',ia,j,1) ) * Area(ia) * AreaScale ]*0.2: >10:0;
				ParTmp := sum[ ia | KmPlotToLoc(ia,CurrFacInLoc(fa)) < 300, 
					max( (j) | j in xToRun(ia), PlotOutput('BerTim',ia,j,1) ) * 
					Area(ia) * AreaScale * KmPlotToLoc(ia,CurrFacInLoc(fa))] ;
				ParTmp2 := Power( sum[ ia | KmPlotToLoc(ia,CurrFacInLoc(fa)) < 300, 
					max( (j) | j in xToRun(ia), PlotOutput('BerTim',ia,j,1) ) * 
					Area(ia) * AreaScale ] + 0.001,-1 );
				put ParTmp * ParTmp2: >10:2;
				put min( f | FacitlityType(f) = 'PuChem' or FacitlityType(f) = 'PuDiss' or FacitlityType(f) = 'PuCTMP', 
					KmLocToLoc(CurrFacInLoc(fa),CurrFacInLoc(f)) ): >10:2;
			
			PUT / ;  
			
			endfor;
			
			PUT / ;  
			PUT/, "Period" ,  @30; for t do PUT t: >10:0; endfor ; PUT / ; 
			
			PUT "Lövmassa till massaindustrin" ,  @30; 
				for t do PUT sum( ft, FAToUse('Decids',ft,1,t)) * 1.e-6: >10:3; endfor ; PUT / ;
			PUT "Bjorksågtimmer till massaindustrin" ,  @30; 
				for t do PUT sum( ft | ft = 'PuChem' or ft = 'PuDiss' or ft = 'PuCTMP', 
					FAToUse('BerTim',ft,1,t)) * 1.e-6: >10:3; endfor ; PUT / ;
			PUT "Bjorksågtimmer till sågverken" ,  @30; 
				for t do PUT FAToUse('BerTim','Sawmbe',1,t) * 1.e-6: >10:3; endfor ; PUT / ;
			PUT "Hybridtimmer till sågverken" ,  @30; 
				for t do 
					PUT sum[ (ia,j) | t >= pA(ia,j) and t <= pB(ia,j) and 
					count( t1 | t1 >= pA(ia,j) and t1 <= pB(ia,j) and Nratg(ia,j,t1) >= 8 and Nratg(ia,j,t1) <= 11) > 0,
					AreaScale * Area(ia) * PlotOutput('BerTim',ia,j,t) * x(ia,j) ]  * 1.e-6 *0.2: >10:3; 
				endfor ; PUT / ;
			PUT "Hybridmassaved till massaverk" ,  @30; 
				for t do 
					PUT sum[ (ia,j) | t >= pA(ia,j) and t <= pB(ia,j) and 
					count( t1 | t1 >= pA(ia,j) and t1 <= pB(ia,j) and Nratg(ia,j,t1) >= 8 and Nratg(ia,j,t1) <= 11) > 0,
					AreaScale * Area(ia) * PlotOutput('Decids',ia,j,t) * x(ia,j) *0.2]  * 1.e-6: >10:3; 
				endfor ; PUT / ;
			PUT "Föryngring med hybrid (ha)" ,  @30; 
				for t do 
					PUT sum[ (ia,j) | t >= pA(ia,j) and t <= pB(ia,j) and Nratg(ia,j,t) >= 8 and Nratg(ia,j,t) <= 11,
					AreaScale * Area(ia) * x(ia,j) ] *0.2  : >10:0; 
				endfor ; PUT / ;
			
			PUT / ;  
			
			PUT/, "Period" ,  @30; for t do put t: >10:0; endfor ; PUT / ;
			empty TableDA;
			for (ia,j,t) | x(ia,j) do
				DiaTab := max(1,(min(40,Dgv(ia,j,t))-12)/2 + 1);
				AgeTab := max(1,(min(130,Age(ia,j,t))-30)/10 + 1);
				TableDA(DiaTab,AgeTab,t) += AreaScale * Area(ia) * PlotOutput('BerTim',ia,j,t) * x(ia,j) * 0.2;
			endfor;
			for (ac,dc) do
				PUT "Age " + (ac*10+20) + "-" + (ac*10+30) + " Dia "  + (dc*2+8) + "-" + (dc*2+10) + ":",  @30; 
				for t do PUT TableDA(dc,ac,t): >10:0; endfor; PUT / ;  
			endfor;
			
			putclose ResultFile ;
		}
	}
	Procedure BiotopAreas {
		Body: {
			empty FOBiotopAreas ;
			
			for r | Card(CountiesInRegions(r)) > 0 do
			
				FOBiotopAreas(1,r,t) := sum[ (y,ia,j) | Hgv(ia,j,t) > 7 and CurrPlotsInCounties(ia) = y and y in CountiesInRegions(r) and	
					m3Pin(ia,j,t) >= 0.65*m3Vol(ia,j,t), Area(ia)*AreaScale*x(ia,j) ] ;
				FOBiotopAreas(2,r,t) := sum[ (y,ia,j) | Hgv(ia,j,t) > 7 and CurrPlotsInCounties(ia) = y and y in CountiesInRegions(r) and	
					m3Spr(ia,j,t) >= 0.65*m3Vol(ia,j,t), Area(ia)*AreaScale*x(ia,j) ] ;
				FOBiotopAreas(3,r,t) := sum[ (y,ia,j) | Hgv(ia,j,t) > 7 and CurrPlotsInCounties(ia) = y and y in CountiesInRegions(r) and	
					m3Pin(ia,j,t) < 0.65*m3Vol(ia,j,t) and m3Spr(ia,j,t) < 0.65*m3Vol(ia,j,t) and 
					( m3Pin(ia,j,t) + m3Spr(ia,j,t) ) >= 0.65*m3Vol(ia,j,t), Area(ia)*AreaScale*x(ia,j) ] ;
				FOBiotopAreas(4,r,t) := sum[ (y,ia,j) | Hgv(ia,j,t) > 7 and CurrPlotsInCounties(ia) = y and y in CountiesInRegions(r) and	
					( m3Pin(ia,j,t) + m3Spr(ia,j,t) ) < 0.65*m3Vol(ia,j,t) and m3Dec(ia,j,t) < 0.65*m3Vol(ia,j,t),
					Area(ia)*AreaScale*x(ia,j) ] ;
				FOBiotopAreas(5,r,t) := sum[ (y,ia,j) | Hgv(ia,j,t) > 7 and CurrPlotsInCounties(ia) = y and y in CountiesInRegions(r) and	
					m3Dec(ia,j,t) >= 0.65*m3Vol(ia,j,t), Area(ia)*AreaScale*x(ia,j) ] ;
			
			endfor ;
		}
	}
	Procedure TestOfParticulars {
		Body: {
			PeriodResult(t) := sum[ (ia,j) |  t >= pA(ia,j) and t <= pB(ia,j), AreaScale * Area(ia) * TSbiom(ia,j,t) * x(ia,j) ] * CsharePertTS *1.e-6;
		}
	}
	Procedure MainInitialization;
	Procedure MainExecution {
		Body: {
			!GMP::Solution::RetrieveFromModel( SweForGMP, 1 ) ;
			!GMP::Solution::SendToModel( SweForGMP, 1 ) ;
			!GMP::Instance::Solve( SweForGMP );
		}
	}
	Procedure MainTermination {
		Body: {
			return DataManagementExit();
		}
	}
	DeclarationSection Excel_Linkage {
		StringParameter WorkbookName;
		StringParameter Sheet;
	}
}
