	Procedure PutAgeClasses {
		Body: {
			OutputFileResults := "AgeClasses.txt" ;
			ResultFile.PageWidth := 600 ;
			PUT ResultFile ;
			
			PUT "Ageclass" , @10; PUT "Area":>10, @20; PUT "m3PerHa":>10; PUT / ;
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 3, Scale(i) * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "0" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 3, m3Vol(i,j,1) * Scale(i) * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ; 
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 11 and Age(i,j,1) >= 3, Scale(i) * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "3" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 11 and Age(i,j,1) >= 3, m3Vol(i,j,1) * Scale(i) * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ; 
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 21 and Age(i,j,1) >= 11, Scale(i) * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "11" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 21 and Age(i,j,1) >= 11, m3Vol(i,j,1) * Scale(i) * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 31 and Age(i,j,1) >= 21, Scale(i) * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "21" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 31 and Age(i,j,1) >= 21, m3Vol(i,j,1) * Scale(i) * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 41 and Age(i,j,1) >= 31, Scale(i) * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "31" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 41 and Age(i,j,1) >= 31, m3Vol(i,j,1) * Scale(i) * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 61 and Age(i,j,1) >= 41, Scale(i) * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "41" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 61 and Age(i,j,1) >= 41, m3Vol(i,j,1) * Scale(i) * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 81 and Age(i,j,1) >= 61, Scale(i) * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "61" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 81 and Age(i,j,1) >= 61, m3Vol(i,j,1) * Scale(i) * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 101 and Age(i,j,1) >= 81, Scale(i) * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "81" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 101 and Age(i,j,1) >= 81, m3Vol(i,j,1) * Scale(i) * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 121 and Age(i,j,1) >= 101, Scale(i) * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "101" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 121 and Age(i,j,1) >= 101, m3Vol(i,j,1) * Scale(i) * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) < 141 and Age(i,j,1) >= 121, Scale(i) * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "121" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) < 141 and Age(i,j,1) >= 121, m3Vol(i,j,1) * Scale(i) * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ;  
			
			ParTmp := sum[ (i,j) | Age(i,j,1) >= 141, Scale(i) * x(i,j) ] * 1.e-6 ;
			ParTmp2 := 1/(ParTmp+0.000000001) ;
			PUT "141+" ,  @10; 
				PUT ParTmp: >10:2;
				PUT sum[ (i,j) | Age(i,j,1) >= 141, m3Vol(i,j,1) * Scale(i) * x(i,j) ] * 1.e-6 * ParTmp2: >10:2; 
			PUT / ; 
			
			PUT sum[ (i,j), Scale(i) * x(i,j) ] * 1.e-6 : >10:2; PUT / ; 
			PUT sum[ (i,j), m3Vol(i,j,1) * Scale(i) * x(i,j) ] * 1.e-6 : >10:2; PUT / ; 
			
			putclose ResultFile ;
		}
	}
	Procedure BiotopAreas {
		Body: {
			empty FOBiotopAreas ;
			
			for r | sum[ y, CountyToRegion(y,r) ] > 0 do
			
				FOBiotopAreas(1,r,t) := sum[ (y,ia,j) | Hgv(ia,j,t) > 7 and PlotsToCounties(ia,y) and CountyToRegion(y,r) and	
					m3Pin(ia,j,t) >= 0.65*m3Vol(ia,j,t), Scale(ia)*x(ia,j) ] ;
				FOBiotopAreas(2,r,t) := sum[ (y,ia,j) | Hgv(ia,j,t) > 7 and PlotsToCounties(ia,y) and CountyToRegion(y,r) and	
					m3Spr(ia,j,t) >= 0.65*m3Vol(ia,j,t), Scale(ia)*x(ia,j) ] ;
				FOBiotopAreas(3,r,t) := sum[ (y,ia,j) | Hgv(ia,j,t) > 7 and PlotsToCounties(ia,y) and CountyToRegion(y,r) and	
					m3Pin(ia,j,t) < 0.65*m3Vol(ia,j,t) and m3Spr(ia,j,t) < 0.65*m3Vol(ia,j,t) and 
					( m3Pin(ia,j,t) + m3Spr(ia,j,t) ) >= 0.65*m3Vol(ia,j,t), Scale(ia)*x(ia,j) ] ;
				FOBiotopAreas(4,r,t) := sum[ (y,ia,j) | Hgv(ia,j,t) > 7 and PlotsToCounties(ia,y) and CountyToRegion(y,r) and	
					( m3Pin(ia,j,t) + m3Spr(ia,j,t) ) < 0.65*m3Vol(ia,j,t) and m3Dec(ia,j,t) < 0.65*m3Vol(ia,j,t),
					Scale(ia)*x(ia,j) ] ;
				FOBiotopAreas(5,r,t) := sum[ (y,ia,j) | Hgv(ia,j,t) > 7 and PlotsToCounties(ia,y) and CountyToRegion(y,r) and	
					m3Dec(ia,j,t) >= 0.65*m3Vol(ia,j,t), Scale(ia)*x(ia,j) ] ;
			
			endfor ;
		}
	}
	Procedure TestOfParticulars {
		Body: {
			OutputFileResults := 'TestOfParticulars'; 
			ResultFile.PageWidth := 600 ;
			PUT ResultFile ;
			
			PUT "Hej"; PUT /;
			halt;
			for fa | CurrFT(fa) = 'TerHea' do
				PUT fa; PUT sum[ ia | RelevantTrpFromPlot('ResStm',ia,fa) , TrpCostPlotToFac('ResStm',ia,fa) ]:<20:0; put /;
			endfor;
			
			/*
			for (ia) do
				PUT ia
				+ " age " + Age(ia,First(j),1):<10:1 
				+ " dec " + m3Dec(ia,First(j),1)*Power(m3Vol(ia,First(j),1) + 0.0001,-1):<10:2
				+ " Hgv " + Hgv(ia,First(j),1):<10:1
				+ " Dgv " + Dgv(ia,First(j),1):<10:1  
				+ " Stems " + Stems(ia,First(j),1):<10:1  
				+ " SIS " + SIS(ia,First(j),1):<10:1  
				+ " LSA " + LSA(ia,First(j),1):<10:1  
				+ " Area " + Area(ia):<10:3  
				; put /;
			endfor; */
			
			
			putclose ResultFile ;
		}
	}
	Procedure MainInitialization;
	Procedure MainExecution {
		Body: {
			!GMP::Solution::RetrieveFromModel( SweForGMP, 1 ) ;
			!GMP::Solution::SendToModel( SweForGMP, 1 ) ;
			!GMP::Instance::Solve( SweForGMP );
		}
	}
	Procedure MainTermination {
		Body: {
			return DataManagementExit();
		}
	}
	DeclarationSection Excel_Linkage {
		StringParameter WorkbookName;
		StringParameter Sheet;
	}
	Section Quantities_and_Units {
		Comment: {
			"This section contains all the units and quantities that are added automatically by AIMMS.
			It is recommended to declare all your quantities here."
		}
		Quantity SI_Time_Duration {
			BaseUnit: s;
			Comment: {
				"Expresses the value for the duration of periods.
				
				The unit s has been added automatically because it is a required unit for DataExchange."
			}
		}
	}
}
