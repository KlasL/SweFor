			axll::ReadSet(SetReference: Facility, SetRange: "d2:d400", ExtendSuperSets:  1, MergeWithExistingElements :  1, SkipEmptyCells:  1); ! Line 1
			axll::ReadList(IdentifierReference: FacilityLocation, RowHeaderRange: "d2:d400", DataRange: "a2:a400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadList(IdentifierReference: FacilityType, RowHeaderRange: "d2:d400", DataRange: "e2:e400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadList(IdentifierReference: InitialCapacity, RowHeaderRange: "d2:d400", DataRange: "f2:f400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadSet(SetReference: Facility, SetRange: "g2:g400", ExtendSuperSets:  1, MergeWithExistingElements :  1, SkipEmptyCells: 1); ! Line 2
			axll::ReadList(IdentifierReference: FacilityLocation, RowHeaderRange: "g2:g400", DataRange: "a2:a400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadList(IdentifierReference: FacilityType, RowHeaderRange: "g2:g400", DataRange: "h2:h400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadList(IdentifierReference: InitialCapacity, RowHeaderRange: "g2:g400", DataRange: "i2:i400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadSet(SetReference: Facility, SetRange: "j2:j400", ExtendSuperSets:  1, MergeWithExistingElements :  1, SkipEmptyCells:  1); ! Line 3
			axll::ReadList(IdentifierReference: FacilityLocation, RowHeaderRange: "j2:j400", DataRange: "a2:a400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadList(IdentifierReference: FacilityType, RowHeaderRange: "j2:j400", DataRange: "k2:k400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadList(IdentifierReference: InitialCapacity, RowHeaderRange: "j2:j400", DataRange: "l2:l400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadSet(SetReference: Facility, SetRange: "m2:m400", ExtendSuperSets:  1, MergeWithExistingElements :  1, SkipEmptyCells:  1); ! Line 4
			axll::ReadList(IdentifierReference: FacilityLocation, RowHeaderRange: "m2:m400", DataRange: "a2:a400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadList(IdentifierReference: FacilityType, RowHeaderRange: "m2:m400", DataRange: "n2:n400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadList(IdentifierReference: InitialCapacity, RowHeaderRange: "m2:m400", DataRange: "o2:o400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadSet(SetReference: Facility, SetRange: "p2:p400", ExtendSuperSets:  1, MergeWithExistingElements :  1, SkipEmptyCells:  1); ! Line 5
			axll::ReadList(IdentifierReference: FacilityLocation, RowHeaderRange: "p2:p400", DataRange: "a2:a400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadList(IdentifierReference: FacilityType, RowHeaderRange: "p2:p400", DataRange: "q2:q400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadList(IdentifierReference: InitialCapacity, RowHeaderRange: "p2:p400", DataRange: "r2:r400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadSet(SetReference: Facility, SetRange: "s2:s400", ExtendSuperSets:  1, MergeWithExistingElements :  1, SkipEmptyCells:  1); ! Line 6
			axll::ReadList(IdentifierReference: FacilityLocation, RowHeaderRange: "s2:s400", DataRange: "a2:a400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadList(IdentifierReference: FacilityType, RowHeaderRange: "s2:s400", DataRange: "t2:t400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			axll::ReadList(IdentifierReference: InitialCapacity, RowHeaderRange: "s2:s400", DataRange: "u2:u400", ModeForUnknownElements : 0, MergeWithExistingData  : 1);
			
			axll::CloseWorkBook(WorkbookFilename : WorkbookName );
			
			statusmessage("ReadFacilities complete") ;
		}
	}
	Procedure ReadDistances {
		Body: {
			statusmessage('Reading distances');
			empty KmPlotToLoc,KmLocToLoc;
			dex::AddMapping("PlotToLocMapping","MappingCSV_PlotToLoc.xml");
			dex::ReadFromFile(FileNames('DistancesPlotToLoc'), "PlotToLocMapping");
			dex::AddMapping("LocToLocMapping","MappingCSV_LocToLoc.xml");
			dex::ReadFromFile(FileNames('DistancesLocToLoc'), "LocToLocMapping");
			
			/*
			InputFile := FileNames('DistancesLocToLoc') ;
			read from file InputFile;
			InputFile := FileNames('DistancesPlotToLoc') ;
			read from file InputFile;
			*/
		}
	}
	Procedure SetSets {
		Body: {
			option seed := 1234 ;
			RND(i) := Uniform( 0, 1 )  ;
			PlotToRun := { i | NRatg(i,first(j),1) and RND(i) < RNDrun };
			xToRun(ia) := { j | sum[ t, NRatg(ia,j,t) ] } ;
			
			pB( (ia,j) | j in xToRun(ia) ) := last( t | NRatg(ia,j,t) );
			pA( (ia,j) | j in xToRun(ia) ) := first( t | NRatg(ia,j,t) );
			pA( (ia,j) | pA(ia,j) < LastPeriod and pA(ia,j) < pB(ia,j) and Treatm(ia,j,pA(ia,j)) = 'FF'
				and pA(ia,j) <> FirstPeriod and pB(ia,j) <> LastPeriod) := pA(ia,j) + 1;
			
			if sum[b,FastArea(b)] then
			! Tax plots are represented by stands
				E2S(i) := StringToElement(Parcel,E2Se(i),1);	! coupling stands and parcels
				ParcelArea(b) := sum[ ia | E2S(ia) = b, Area(ia) ]; 
				ParcelToRun := { b | ParcelArea(b) }; ! Index ba
				Scale(ia) := TotalForestArea / Card(ParcelToRun) / ParcelArea(E2S(ia)) * Area(ia);
			else
			! Tax plots are forest
				ParTmp := sum[ia,Area(ia)];
				Scale(ia) := TotalForestArea / ParTmp * Area(ia);
			endif;
			
			CurrFT(f) := StringToElement(FacilityTypesSet,FacilityType(f)) ;
			Facility -= { f | InitialCapacity(f) < MinCapacityQuantity(CurrFT(f)) or not CurrFT(f) in FacilityTypesSet };
			CurrFacInLoc(f) := StringToElement( Location, FacilityLocation(f) ) ;
			Location := { l | Count[ f | CurrFacInLoc(f) = l ]  } ;
			Facility -= { f | not CurrFacInLoc(f) in Location };
			
			statusmessage("Adding superlocations and superfacilities") ;
			Location += data { 'SuperLoc' } ;
			for ft do
				CharTmp := FacilityTypesChar(ft) ;
				CurrFac := StringToElement(Facility,CharTmp) ; 
				SetElementAdd( Facility, CurrFac, CharTmp );
				SuperFacility += CurrFac ;
				FacilityType(CurrFac) := CharTmp ;
				CurrFT(CurrFac) := ft ;
				FacilityLocation(CurrFac) := 'SuperLoc' ;
				CurrFacInLoc(CurrFac) := StringToElement( Location, FacilityLocation(CurrFac) ) ;
				InitialCapacity(CurrFac) := 
					sum[ f | CurrFT(f) = ft and CurrFacInLoc(f) <> 'SuperLoc', InitialCapacity(f) ] ;
			endfor ;
		}
	}
	Procedure ManageTransports {
		Body: {
			! Define transport related sets
			RelevantInput( (fin,f) | sum[ fut, abs( TabInUtFacilityType(CurrFT(f),fin,fut) ) ] > 0 ) := 1 ;
			RelevantOutput( (fut,f) | sum[ fin, abs( TabInUtFacilityType(CurrFT(f),fin,fut) ) ] > 0 ) := 1 ;
			SideFactor := { fut | Count( (fin,ft) | TabInUtFacilityType(ft,fin,fut) < 0 ) } ;
			TrpFactor := { fin | ChTrpFactors(fin) = "Y" };
			
			statusmessage("Computing relevant transport options - Plot to facility") ;
			empty RelevantTrpFromPlot, RelevantTrpBetwFac, BestTrpToFacA, BestTrpToFacB ;
			
			! missing distances
			KmPlotToLoc( (ia,l) | KmPlotToLoc(ia,l) = 0 and
				SQRT( (GpsEastI(ia)-GpsEastL(l))^2 + (GpsNorthI(ia)-GpsNorthL(l))^2 ) / 1000 * Slinger < 
					min[ fin | CommodityType(fin) = "L", MaxTrpDistance(fin) ] ) :=
					SQRT( (GpsEastI(ia)-GpsEastL(l))^2 + (GpsNorthI(ia)-GpsNorthL(l))^2 ) / 1000 * Slinger; 
			KmLocToLoc( (l1,l2) | KmLocToLoc(l1,l2) = 0 and l1 <> l2 ) := 
				SQRT( (GpsEastL(l1)-GpsEastL(l2))^2 + (GpsNorthL(l1)-GpsNorthL(l2))^2 ) / 1000 * 2 ;
			
			
			! Let all facilities be active incl. superfacilities (to get relevant distance)
			for ia do
				BestTrpToFacA := Sort( f | 
					KmPlotToLoc(ia,CurrFacInLoc(f)) and not f in SuperFacility , - KmPlotToLoc(ia,CurrFacInLoc(f))) ;
				for (fin,ft) | ExtractionRate(fin) and MaxNoTrpLinks(fin,ft) do
					BestTrpToFacB := NBest( fb | CurrFT(fb) = ft and RelevantInput(fin,fb) and KmPlotToLoc(ia,CurrFacInLoc(fb)) < MaxTrpDistance(fin),
						- KmPlotToLoc(ia,CurrFacInLoc(fb)), MaxNoTrpLinks(fin,ft) ) ;
					RelevantTrpFromPlot( (fin,ia,fc) | fc in Facility) := 1 ;
					CurrFac := Element(BestTrpToFacB,1) ;
					RelevantTrpFromPlot( (fin,ia,fs) | CurrFT(fs) = ft ) := 
						RelevantTrpFromPlot(fin,ia,CurrFac) ; 
				endfor ;
			endfor ;
			
			! Come here to determine the active set of facilities t
			if RunMode = 'sup' then 
				Facility := SuperFacility ;
			else 
				Facility := Facility - SuperFacility ;
			endif ;
			ActiveFacility := Facility;
			
			statusmessage("Computing relevant transport options - Facility to facility - non Min spanning tree") ;
			for (ft,fut,f1) | fut in TrpFactor
				and not f1 in SuperFacility ! Calculated based on average transport distances
				and MaxNoTrpLinks(fut,ft) and RelevantOutput(fut,f1) do
				BestTrpToFacA := NBest( f2 | RelevantInput(fut,f2) and CurrFT(f2) = ft   
					and KmLocToLoc(CurrFacInLoc(f1),CurrFacInLoc(f2)) and KmLocToLoc(CurrFacInLoc(f1),CurrFacInLoc(f2)) < MaxTrpDistance(fut),
					- KmLocToLoc(CurrFacInLoc(f1),CurrFacInLoc(f2)), MaxNoTrpLinks(fut,ft) ) ;
				RelevantTrpBetwFac(fut,f1,fb) := 1 ;
			endfor ; 
			
			RelevantTrpBetwFac( (fut,f1,f2) | f1 <> f2 and CurrFacInLoc(f1) = CurrFacInLoc(f2) 
				and RelevantOutput(fut,f1) and RelevantInput(fut,f2) ) := 1;
			
			! Treat0: Fina = 6; Thin = 3; PCT = 2; System 1 for GROT, system 2 for stumps (Dimitris ... 2017: Regional GIS-based evaluation...)
			statusmessage("Computing transport costs") ;
			empty TrpCostPlotToFac, TrpCostFacToFac;
			
			TrpCostPlotToFac( (fin,ia,f) | RelevantTrpFromPlot(fin,ia,f) ) := 
				FixTrpCost(fin) + VarTrpCost(fin) * KmPlotToLoc(ia,CurrFacInLoc(f));
			TrpCostFacToFac( (fut,f1,f2) | RelevantTrpBetwFac(fut,f1,f2) and CurrFacInLoc(f1) <> CurrFacInLoc(f2) ) :=
				FixTrpCost(fut) + VarTrpCost(fut) * KmLocToLoc(CurrFacInLoc(f1),CurrFacInLoc(f2));
			
			TrpCostFacToFac( (fut,f1,f2) | RelevantTrpBetwFac(fut,f1,f2) and f2 in SuperFacility
				and CurrFT(f2) <> 'Heatpl' and CurrFT(f2) <> 'TerHea' ) := 
					FixTrpCost(fut) + VarTrpCost(fut) * 93;
			TrpCostFacToFac( (fut,f1,f2) | RelevantTrpBetwFac(fut,f1,f2) and f2 in SuperFacility
				and ( CurrFT(f2) <> 'Heatpl' or CurrFT(f2) <> 'TerHea' ) ) := 
					FixTrpCost(fut) + VarTrpCost(fut) * 63;
			
			statusmessage("ManageTransports completed") ;
		}
	}
