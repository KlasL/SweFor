		Procedure RunNVK {
			Body: {
				!-- Read and save forest data
				FileNames('Forest')     		:= "D:/Users/ljeraa/BioFrame/BioframeData/ForestAllToAIMMS.txt";
				FileNames('Factors')    		:= "D:/Users/ljeraa/BioFrame/BioframeData/FactorsToAIMMS.txt";
				FileNames('ForestSave') 		:= "D:/Users/ljeraa/BioFrame/SweForData/NVKstudy/NVKTest.data";
				!-- Distance matrices
				FileNames('DistancesLocToLoc') 	:= "D:/Users/ljeraa/BioFrame/SweForData/Cement/DistancesLocToLocWithTerminals.csv";
				FileNames('DistancesPlotToLoc')	:= "D:/Users/ljeraa/BioFrame/SweForData/NVKstudy/PlotToLoc.csv";
				!-- Read forest reltaed data
				FileNames('ForestMerge') 		:= "D:/Users/ljeraa/BioFrame/SweForData/NVKstudy/NVK.data";
				FileNames('SegmentData') 		:= "D:/Users/ljeraa/BioFrame/SweForData/NVKstudy/SegmentData_new.csv";
				!-- Facilities and input/output related data
				FileNames('InputOutputData')	:= "D:/Users/ljeraa/BioFrame/SweForData/NVKstudy/InputOutputV2601.xlsx";
				FileNames('FacilityData')   	:= "D:/Users/ljeraa/BioFrame/SweForData/Cement/SweForFacilytyData#3.xlsx";
				!-- Output results
				FileNames('RegionResult')       := "D:/Users/ljeraa/BioFrame/SweForData/MMBpayment/Res_BAU.csv";
				
				!--- All data preparation including saving
				statusmessage("ReadingGAYData") ;
				!ReadAndSaveGAYAData;
				statusmessage("Reading StandAndPlotData") ;
				ReadStandAndPlotData ;
				statusmessage("ReadStandAndPlotData OK") ;
				ReadIO;
				ReadFacilities ;
				statusmessage("ReadIOandFacilities OK") ;
				ReadDistances ;
				statusmessage("ReadDistances OK") ;
				SetSets;
				! Add NVK priority set asides on top of standard setasides
				empty ParTmp, BestSetAsideIndex ;
				BestSetAsideIndex := sort( ia | NVKprob(ia), - NVKprob(ia) ) ;
				TotSetAsideArea := sum[ ia, Scale(ia) ] * SetasideRate * 2. - sum[ ia | hasSetAside(ia), Scale(ia) ];
				for ib | hasSetAside(ib) = 0 do
					hasSetAside(ib) := 1 ;
					ParTmp += Scale(ib) ;
					if ParTmp > TotSetAsideArea then
						dialogmessage(NVKprob(ib));
						break ;
					endif ;
				endfor ;
				statusmessage("SetSets OK") ;
				ManageTransports ;
				statusmessage('ManageTransports completed') ;
				SolveMaxNetSurplus ;
				PutRegionResults;
			}
		}
		Procedure SolveGMP {
			Body: {
				!-- Set up problem
				empty x, x.ReducedCost, SaveRC;
				
				!-- Step 1: derive shadow prices to start with after running:
				!-- (i) w. SweForGMP, (ii) running with SweForGMP
				TotalSupply.Lower( (fut,t) |  CommodityType(fut) = 'D' or CommodityType(fut) = 'F' ) := q0(fut,t);
				ActiveFacility := Facility - SuperFacility ;
				statusmessage('Solving 1');
				SweForGMP := GMP::Instance::Generate( MaxNetSurplus, "MaxNetSurplus" ) ;
				
				!-- Step 2: 
				Iter1 := 0 ;
				RelativeImprovm := 1 ;
				while Iter1 < 5 do
					statusmessage("Solving with All facilities - limited x variables: " + Iter1);
					GMP::Instance::Solve( SweForGMP ); 
					ObjectiveValue := GMP::Solution::GetObjective( SweForGMP, 1 );
					dialogmessage( ObjectiveValue );
					Iter1 += 1 ;
				endwhile ;
				
				statusmessage("Initial Problem solves with FixedDemand for 4 periods");
				for (fut,t) | t <= 1 and CommodityType(fut) = 'D' or CommodityType(fut) = 'F' do
					GMP::Column::SetUpperBound( SweForGMP, TotalSupply(fut,t), q0(fut,t) );
					GMP::Column::SetLowerBound( SweForGMP, TotalSupply(fut,t), q0(fut,t) );
				endfor;
				halt; 
				
				FixedDemand(fut,t) := q0(fut,t);
				for (fut,t) | t <= 4 and fut = 'Heat__' or fut = 'BioFue' do
					GMP::Column::SetUpperBound( SweForGMP, TotalSupply(fut,t), 0 );
					GMP::Row::SetRightHandSide( SweForGMP, ConMinSupply(fut,t), FixedDemand(fut,t) );
					GMP::Column::SetUpperBound( SweForGMP, Export(fut,t), 0 );
				endfor;	
				statusmessage("Problem solved with FixedDemand = q0 and limited no. x");
				GMP::Instance::Solve( SweForGMP ); 
				halt;
			}
		}
	}
