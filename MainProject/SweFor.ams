	Procedure RunAnalysis {
		Body: {
			!-- Select plots and activities ----------------------------------------------------------------------------
			! No harvesting on small stands
			xToRun( ia | Area(ia) < 0.1 ) -= { j | count( t, Treatm(ia,j,t) <> 'NM' ) > 0 }  ; 
			! Include only eligible age for final harvest
			xToRun(ia) -= 
				{ j | count( t, t = pB(ia,j) and Treatm(ia,j,t) = 'FF' and Age(ia,j,t) < RelativLSA * LSA(ia,j,t) ) > 0 };
			! Remove final felling from "fjärrnära skog"
			xToRun(ia) -= 
				{ j | count( t, t = pB(ia,j) and Treatm(ia,j,t) = 'FF' and Fjanara(ia) > 0  ) > 0 };
			! Old forest
			!xToRun(ia ) -= { j | ( count( t, TCc(Treat0(ia,j,t)) = 'FF' and NUTS2I(ia) >= 30 and Age(ia,j,t) >= 140 ) +	
			!		count( t, TCc(Treat0(ia,j,t)) = 'FF' and NUTS2I(ia) < 30 and Age(ia,j,t) >= 120) ) > 0 } ;
			! Only do nothing allowed	
			!TCc(Treat0(ia,j,t)) = 'FF' and NUTS(ia) < 30 and Age(ia,j,t) >= 120, 1 ] = 0
				!	and sum[ t, m3Harv(ia,j,t)] = 0	!		};
			! None allowed to fertilize
			!xToRun(ia ) -= { j | ( count( t, TCc(Treat0(ia,j,t)) = 'Fe' ) + count( t, TCc(Treat0(ia,j,t)) = 'FT'  ) ) > 0 } ;
			! Private are not allowed to fertilize		
			xToRun(ia ) -= { j | OwnTyp(ia) = 'Private' and ( count( t, Treatm(ia,j,t) = 'Fe' ) + count( t, Treatm(ia,j,t) = 'FT' ) ) > 0 }  ;
			! Fertilize only prior to final felling
			xToRun(ia ) -= { j | ( count( t, Treatm(ia,j,t) = 'Fe'  and Treatm(ia,j,t+2) <> 'FF')  ) > 0 }  ;
			! Exclude non-managed land and include among set aside area	
			empty hasSetAside;
			hasSetAside( ia | CountyI(ia) >= 20 and Age(ia,First(j),1) >= 140 + 20 or CountyI(ia) < 20 and Age(ia,First(j),1) >= 120 + 20 ) := 1 ;
			SetSetAsides;
			!hasSetAside( ia | count( j | TCc(Treat0(ia,j,1)) = 'NM' and TCc(Treat0(ia,j,2)) = 'NM' and Age(ia,j,1) > LSA(ia)*1.3 
			!	and (m3Vol(ia,j,2) - m3Vol(ia,j,1))/(m3Vol(ia,j,1)+0.001) < (1-exp(-0.005*5))) > 1 ) := 1 ;
			xToRun( ia | hasSetAside(ia) ) -= { j | count( t, Treatm(ia,j,t) <> 'NM' ) > 0 }  ; 
			!-- End: Select plots and activities -----------------
			
			empty x;
			if RunMode = 'GMP' then 
				SolveGMPrnd;
				halt;
			elseif RunMode = '1old' then 
				CaseFileLoad( "Solution1.data" ) ;
				xToRun(ia ) -= { j | x(ia,j).level = 0 };
			elseif RunMode = '2old' then 
				CaseFileLoad( "Solution2.data" ) ;
				xToRun(ia ) -= { j | x(ia,j).level = 0 };
			elseif RunMode = '2fix' then 
				CaseFileLoad( "BAU_V12.1.data" ) ;
				xToRun(ia ) -= { j | x(ia,j).level = 0 };
				x( (ia,j) | j in xToRun(ia) ).Upper := x(ia,j);
				x( (ia,j) | j in xToRun(ia) ).Lower := x(ia,j);
			endif;
			
			!-- Add bounds data -------------------------------------------------------------------
			empty TotalSupply,NetOutputAtFacility;
			TotalSupply.Lower( (fut,t) |  CommodityType(fut) = 'D' ) := q0(fut,t);
			NetOutputAtFacility.Lower( (fut,fa,t) | CommodityType( StringToElement(Factor,FactorForCapacity(CurrFT(fa))) ) = 'F'  ) := 
				q0(StringToElement(Factor,FactorForCapacity(CurrFT(fa))),t) * InitialCapacity(fa) / 
				sum[ f | f in ActiveFacility and CurrFT(f) = CurrFT(fa), InitialCapacity(f) ];
			
			statusmessage('Solving: ' + RunMode);
			solve MaxNetSurplus ;
			if MaxNetSurplus.Objective = NA then
				halt;
				SolveGMPrnd;
				statusmessage('Solved: SolveGMPrnd');
				PutRegionResults;
			else
				statusmessage('Solved: ' + RunMode);
				if RunMode = 'all' then 
					CaseFileSave( "Solution2.data", SolutionIdentifiers ) ;
				endif;
			endif;
		}
	}
	Procedure PutRegionResults {
		Body: {
			DisplacementModel ;
			BiotopAreas ;
			
			OutputFileResults := FileNames('RegionResult') ;
			ResultFile.PageWidth := 600 ;
			PUT ResultFile ;
			
			PUT "SumTotArea",@20,FOSumTotArea:>20:0, / ;
			PUT "SumManagedArea",@20,FOSumManagedArea:>20:0, / ;
			PUT "NoActivePlots",@20,sum[ ia, 1 ]:>20:0, / ;
			PUT "NoActivex",@20,Count( (ia,j), j in xToRun(ia) and x(ia,j).Upper = 1 ):>20:0, / ;
			PUT "NoOfTrpActivities",@20,( sum[ (fin,ia,fa), RelevantTrpFromPlot(fin,ia,fa) ] 
				+ sum[ (fut,f1,f2) | f1 in ActiveFacility and f2 in ActiveFacility, RelevantTrpBetwFac(fut,f1,f2)  ] ):>20:0, / ;
			PUT "ObjectiveValue",@20,MaxNetSurplus.Objective * 1.e-9:>20:4, / ;
			PUT "NPVRevenue",@20,sum[ t, df(t)* RevenuePerT(t) ] * PeriodLength(1) * 1.e-6:>20:0, / ;
			PUT "NPVCosts",@20,sum[ t, df(t)* CostsPerT(t) ] * PeriodLength(1) * 1.e-6:>20:0, / ;
			PUT "NPVAmenity",@20,sum[ t, df(t)* AmenityPerT(t) ] * PeriodLength(1) * 1.e-6:>20:0, / ;
			PUT "NPVTrade",@20,sum[ t, df(t)* TradePerT(t) ] * PeriodLength(1) * 1.e-6:>20:0, / ;
			PUT "NPVCvalue",@20,df(min(ForestCValuePeriods+1,LastPeriod)) * CValue * PeriodLength(1) * 1.e-6:>20:0, / ;
			PUT "SetAsideValue",@20,df(FirstPeriod) * SetAsideValue * PeriodLength(1) * 1.e-6:>20:0, / ;
			PUT "ForestEndValue",@20,df(LastPeriod) * EndingValue * PeriodLength(1) * 1.e-6:>20:0, / ;
			
			PUT "Period" ,  @30; for t do PUT t: >10:0; endfor ; PUT / ; 
			PUT "HarvestCost" ,  @30; for t do PUT HarvestCost(t) * 1.e-6: >10:0; endfor ; PUT / ;
			PUT "TrpCost" ,  @30; for t do PUT TrpCost(t) * 1.e-6: >10:0; endfor ; PUT / ;
			PUT "FacilityCost" ,  @30; for t do PUT FacilityCost(t) * 1.e-6: >10:0; endfor ; PUT / ;
			PUT "CapacityCost" ,  @30; for t do PUT CapacityCost(t) * 1.e-6: >10:0; endfor ; PUT / ;
			PUT "CarbonValue", @30; for t do PUT -99 >10:0; endfor ; PUT / ;
			
			PUT /; ! Non regional values
			
			for fut | CommodityType(fut) = 'P' or CommodityType(fut) = 'D' or  CommodityType(fut) = 'F' do CurrFact := fut ; 
					PUT "Prices_", FormatString("%e", CurrFact ),  @30; for t do PUT p0(fut,t) : >10:0; endfor ; PUT / ;
			endfor ;  
			for fut | Elasticity(fut)  do CurrFact := fut ; 
					PUT "Prices_", FormatString("%e", CurrFact ),  @30; for t do PUT FinalPrices(fut,t) : >10:0; endfor ; PUT / ;
			endfor ; 
			for fin | MaxImports(fin,1) do CurrFact := fin ; 
				PUT "Import_", FormatString("%e", CurrFact ),  @30; 
					for t do PUT ConImports(fin,t).ShadowPrice * Power(df(t),-1) : >10:0; endfor ; PUT / ;
			endfor ; 
			for fut | CommodityType(fut) = 'P' or CommodityType(fut) = 'D' or  CommodityType(fut) = 'F' or CommodityType(fut) = 'E' do CurrFact := fut ; 
				PUT "SupplyToMarket_", FormatString("%e", CurrFact ),  @30; for t do PUT FATotFactorSupply(fut,t) * 1.e-6: >10:3; endfor ; PUT / ;
			endfor ; 
			
			PUT / ;
			PUT "NCE" ,  @30; for t do PUT NCE(t) * 1.e-6: >10:2; endfor ; PUT / ; 
			PUT "DpTreeDiffStock" ,  @30; for t do PUT DpTreeDiffStock(t) * 1.e-6: >10:2; endfor ; PUT / ; 
			PUT "DpSoilDiffSTock" ,  @30; for t do PUT DpSoilDiffSTock(t) * 1.e-6: >10:2; endfor ; PUT / ; 
			PUT "DpProdDiffStock" ,  @30; for t do PUT DpProdDiffStock(t) * 1.e-6: >10:2; endfor ; PUT / ; 
			PUT "DpSubProd" ,  @30; for t do PUT DpSubProd(t) * 1.e-6: >10:2; endfor ; PUT / ; 
			PUT "DPSubEol" ,  @30; for t do PUT DPSubEol(t) * 1.e-6: >10:2; endfor ; PUT / ; 
			PUT "DpOrganicSoil" ,  @30; for t do PUT DpOrganicSoil(t) * 1.e-6: >10:2; endfor ; PUT / ; 
			PUT "LivingC" ,  @30; for t do PUT LivingC(t) * 1.e-6: >10:2; endfor ; PUT / ; 
			PUT "AfterHarvestFine" ,  @30; for t do PUT AfterHarvestFine(t) * 1.e-6 * 0.2: 10:2; endfor ; PUT / ; 
			PUT "AfterHarvestCoarse" ,  @30; for t do PUT AfterHarvestCoarse(t) * 1.e-6 * 0.2: >10:2; endfor ; PUT / ; 
			PUT "LitterFall" ,  @30; for t do PUT LitterFall(t) * 1.e-6 * 0.2: >10:2; endfor ; PUT / ; 
			PUT "TotSoilC" ,  @30; for t do PUT TotSoilC(t) * 1.e-6: >10:2; endfor ; PUT / ;
			
			for r | sum[ y, CountyToRegion(y,r) ] do
			
			PUT /, "Region ", @30; for y | CountyToRegion(y,r) do PUT y:>3:0; endfor ; PUT / ;
			
			PUT "MgMArea SAcompArea SATotArea NoMgMnoSA", @40;
				PUT FOMgMArea(r):<10:0; PUT FOSAcompArea(r):<10:0; PUT FOSATotArea(r):<10:0; PUT FONoMgMnoSA(r):<10:0;
			
			PUT/, "Period" ,  @30; for t do PUT t: >10:0; endfor ; PUT / ; 
			
				for t do PutPeriod(t) :=  
					sum[ fin | CommodityType(fin) = 'L', FAtonKm(fin,r,t) ] /
					( sum[ fin | CommodityType(fin) = 'L', FAton(fin,r,t) ] + 1 ); endfor ;
				PUT "tonKmLogs" ,  @30; for t do PUT PutPeriod(t):>10:1; endfor ; PUT / ;
			
				for t do PutPeriod(t) :=  
					sum[ fin | CommodityType(fin) = 'R', FAtonKm(fin,r,t) ] /
					( sum[ fin | CommodityType(fin) = 'R', FAton(fin,r,t) ] + 1 ); endfor ;
				PUT "tonKmReidues" ,  @30; for t do PUT PutPeriod(t):>10:1; endfor ; PUT / ;
				PUT "m3VolTot" ,  @30; for t do PUT FOm3HarvVolTot(r,t) * 1.e-6: >10:2; endfor ; PUT / ;
				PUT "m3VolTotPCT" ,  @30; for t do PUT FOm3VolTotPCT(r,t) * 1.e-6: >10:2; endfor ; PUT / ;
				PUT "m3VolTotThin" ,  @30; for t do PUT FOm3VolTotThin(r,t) * 1.e-6: >10:2; endfor ; PUT / ;
				PUT "m3VolTotFina" ,  @30; for t do PUT FOm3VolTotFina(r,t) * 1.e-6: >10:2; endfor ; PUT / ;
				PUT "AreaTotPCT" ,  @30; for t do PUT FOareaTotPCT(r,t) * 1.e-3: >10:0; endfor ; PUT / ;
				PUT "AreaTotThin" ,  @30; for t do PUT FOareaTotThin(r,t) * 1.e-3: >10:0; endfor ; PUT / ;
				PUT "AreaTotFina" ,  @30; for t do PUT FOareaTotFinal(r,t) * 1.e-3: >10:0; endfor ; PUT / ;
				PUT "AreaTotFert" ,  @30; for t do PUT FOareaTotFert(r,t) * 1.e-3: >10:0; endfor ; PUT / ;
				PUT "ThinningPercent" ,  @30; for t do 
					PUT FOm3VolTotThin(r,t) * Power( FOm3HarvVolTot(r,t) + 0.01, -1 ): >10:2; 
				endfor ; PUT / ;
				PUT "StandingVol" ,  @30; for t do PUT FOStandingVol(r,t) * 1.e-6: >10:0; endfor ; PUT / ;
				PUT "m3VolPerHa" ,  @30; for t do PUT FOStandingVol(r,t) * Power( FOMgMArea(r) + 0.0001, -1 ): >10:0; endfor ; PUT / ;
				PUT "noSetAsideVol" ,  @30; for t do PUT FOnoSetAsideVol(r,t) * 1.e-6: >10:0; endfor ; PUT / ;
				PUT "noSetAsidePerHa" ,  @30; for t do 
					PUT FOnoSetAsideVol(r,t) * Power( FOMgMArea(r) - FOSATotArea(r) + 0.0001, -1 ): >10:0; 
				endfor ; PUT / ;
				PUT "PineShare" ,  @30; for t do PUT FOPine(r,t) * Power( FOStandingVol(r,t) + 0.01, -1 ): >10:2; endfor ; PUT / ;
				PUT "SpruceShare" ,  @30; for t do PUT FOSpruce(r,t) * Power( FOStandingVol(r,t) + 0.01, -1 ): >10:2; endfor ; PUT / ;
				PUT "DecidiousShare" ,  @30; for t do PUT FODeciduous(r,t) * Power( FOStandingVol(r,t) + 0.01, -1 ): >10:2; endfor ; PUT / ;
				PUT "NetGrowth" ,  @30; for t do PUT FONetGrowth(r,t) * Power( FOMgMArea(r) + 0.0001, -1 ): >10:2; endfor ; PUT / ;
				PUT "Mortality" ,  @30; for t do PUT FOMortality(r,t) * Power( FOMgMArea(r) + 0.0001, -1 ): >10:2; endfor ; PUT / ;
				PUT "Gross_incr." ,  @30; for t do PUT ( FONetGrowth(r,t) + FOMortality(r,t) ) * Power( FOMgMArea(r) + 0.0001, -1 ): >10:2; endfor ; PUT / ;
				PUT "Gross_incr._%" ,  @30; for t do PUT ( FONetGrowth(r,t) + FOMortality(r,t) ) * Power( FOStandingVol(r,t) + 0.01, -1 ) * 100: >10:2; endfor ; PUT / ;
				PUT "Sawtimber" ,  @30; for t do PUT FOTimber(r,t) * 1.e-6: >10:2; endfor ; PUT / ;
				PUT "Pulpwood" ,  @30; for t do PUT FOPulpw(r,t) * 1.e-6: >10:2; endfor ; PUT / ;
				PUT "AgeFinalFell" ,  @30; for t do PUT FOAgeFina(r,t) * Power( FOm3VolTotFina(r,t) + 0.01, -1 ): >10:2; endfor ; PUT / ;
				PUT "AgeThin" ,  @30; for t do PUT FOAgeThin(r,t) * Power( FOm3VolTotThin(r,t) + 0.01, -1 ): >10:2; endfor ; PUT / ;
				PUT "DiaFinalFell" ,  @30; for t do PUT FODiaFina(r,t) * Power( FOm3VolTotFina(r,t) + 0.01, -1 ): >10:2; endfor ; PUT / ;
				PUT "DiaThinning" ,  @30; for t do PUT FODiaThin(r,t) * Power( FOm3VolTotThin(r,t) + 0.01, -1 ): >10:2; endfor ; PUT / ;
				PUT "RelAboveLSAPriv" ,  @30; for t do PUT FORelVolAboveLSAPriv(r,t) : >10:2; endfor ; PUT / ; 
				PUT "RelAboveLSANonPriv" ,  @30; for t do PUT FORelVolAboveLSANonPriv(r,t) : >10:2; endfor ; PUT / ; 
				PUT "TotResìduesFF" ,  @30; for t do PUT FOResStmTot(r,t) * 1.e-6: >10:2; endfor ; PUT / ;
				PUT "TotStumpsFF" ,  @30; for t do PUT FOResRotTot(r,t) * 1.e-6: >10:2; endfor ; PUT / ;
				PUT "AvailResìdues" ,  @30; for t do PUT FOResStmAvailable(r,t) * 1.e-6: >10:2; endfor ; PUT / ;
				PUT "AvailStumps" ,  @30; for t do PUT FOResRotAvailable(r,t) * 1.e-6: >10:2; endfor ; PUT / ;
				PUT "Area_Age40" ,  @30; for t do PUT FOAge40(r,t) * 1.e-3: >10:0; endfor ; PUT / ;
				PUT "Area_Age80" ,  @30; for t do PUT FOAge80(r,t) * 1.e-3: >10:0; endfor ; PUT / ;
				PUT "Area_Age120" ,  @30; for t do PUT FOAge120(r,t) * 1.e-3: >10:0; endfor ; PUT / ;
				PUT "Area_Age120+" ,  @30; for t do PUT FOAge121(r,t) * 1.e-3: >10:0; endfor ; PUT / ;
				PUT "Area_OldForest" ,  @30; for t do PUT FOOldForest(r,t) * 1.e-3: >10:0; endfor ; PUT / ;
				PUT "MvolFina" ,  @30; for t do PUT FOm3VolTotFina(r,t) * Power( FOareaTotFinal(r,t) + 0.01, -1 ): >10:2; endfor ; PUT / ;
				PUT "MvolThin" ,  @30; for t do PUT FOm3VolTotThin(r,t) * Power( FOareaTotThin(r,t) + 0.01, -1 ): >10:2; endfor ; PUT / ;
				for tc do
					PUT BiotopNames(tc) ,  @30; for t do PUT FOBiotopAreas(tc,r,t) * 1.e-3: >10:0; endfor ; PUT / ;
				endfor ;
				for fut | CommodityType(fut) = 'P' or CommodityType(fut) = 'D' or  CommodityType(fut) = 'F' or CommodityType(fut) = 'E' do CurrFact := fut ; 
					PUT "TotalOutput_", FormatString("%e", CurrFact ),  @30; for t do PUT FATotFactorOutput(fut,r,t) * 1.e-6: >10:3; endfor ; PUT / ;
				endfor ; 
			
			PUT /; ! Miscellenaneous
			
			for (fin,ft) | fin in TrpFactor and sum[ fut, abs( TabInUtFacilityType(ft,fin,fut) ) ] do
				PUT FormatString("%e", ft )," ", FormatString("%e", fin ), @30; 
					for t do PUT FAToUse(fin,ft,r,t) * 1.e-6: >10:3; endfor ; PUT / ;
			endfor ; 
			
			endfor ; ! End regions
			
			putclose ResultFile ;
		}
	}
	Procedure ReadTaxplots {
		Body: {
			!-- Reading from Excel file data on NFI plots
			axll::CloseAllWorkbooks;
			
			empty Plot ;
			
			/*if SLUorLNU = 'LNU' then
				WorkbookName := "D:/BioFrameData/NFI1418.xlsx";
			elseif SLUorLNU = 'ANU' then
				WorkbookName := "C:/Users/jola/AIMMS_NiSync/SweFor4/BioFrameData/NFI1418.xlsx";
			else
				WorkbookName := "C:/Users/jola.old/jola/Projekt/LNU/BioFrame/BioFrameGAYA/NFI1418.xlsx";
			endif ; */
			!WorkbookName := Drive + "NFI1422.xlsx" ;
			axll::OpenWorkBook(WorkbookFilename : WorkbookName);
			
			axll::SelectSheet(SheetName : "NFI1422_input" );
			axll::ReadSet(SetReference: Plot, SetRange: "a2:a60000", ExtendSuperSets:  1, MergeWithExistingElements :  0, SkipEmptyCells:  0);
			
			axll::ReadList(IdentifierReference: Class, RowHeaderRange: "a2:a60000", DataRange: "b2:b60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: GpsEastI, RowHeaderRange: "a2:a60000", DataRange: "e2:e60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: GpsNorthI, RowHeaderRange: "a2:a60000", DataRange: "f2:f60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: Area, RowHeaderRange: "a2:a60000", DataRange: "d2:d60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: RND, RowHeaderRange: "a2:a60000", DataRange: "c2:c60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: PartOfSweden, RowHeaderRange: "a2:a60000", DataRange: "o2:o60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: NUTS2I, RowHeaderRange: "a2:a60000", DataRange: "p2:p60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: OwnTyp, RowHeaderRange: "a2:a60000", DataRange: "v2:v60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: mToRoad, RowHeaderRange: "a2:a60000", DataRange: "t2:t60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: Slope, RowHeaderRange: "a2:a60000", DataRange: "u2:u60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: SoilMoist, RowHeaderRange: "a2:a60000", DataRange: "n2:n60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: Vegetat, RowHeaderRange: "a2:a60000", DataRange: "j2:j60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: Altitude, RowHeaderRange: "a2:a60000", DataRange: "h2:h60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: InitDeadAbove, RowHeaderRange: "a2:a60000", DataRange: "x2:x60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: Peat, RowHeaderRange: "a2:a60000", DataRange: "l2:l60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: SIS, RowHeaderRange: "a2:a60000", DataRange: "s2:s60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: CountyI, RowHeaderRange: "a2:a60000", DataRange: "q2:q60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			axll::ReadList(IdentifierReference: Fjanara, RowHeaderRange: "a2:a60000", DataRange: "y2:y60000", ModeForUnknownElements : 0, MergeWithExistingData  : 0);
			
			axll::CloseWorkBook(WorkbookFilename : WorkbookName );
		}
	}
	Procedure DisplacementModel {
		Body: {
			empty ProdStock, DpTreeDiffStock, DpSoilDiffSTock, DpProdDiffStock, DpSubProd, DPSubEol, DpOrganicSoil, NCE ;
			
			! Living tree carbon stock change
			DpTreeDiffStock(t) := ( LivingC(t) - LivingC(t+1) )/PeriodLength(t) ;
			
			! Mineral soil carbon
			DpSoilDiffSTock(t) := ( TotSoilC(t) - TotSoilC(t+1) )/PeriodLength(t) ;
			
			! Organic soil carbon
			DpOrganicSoil(t) := sum[ (ia,j) |  
				t >= pA(ia,j) and t <= pB(ia,j) and Peat(ia)="1", Scale(ia) * 0.88  * x(ia,j) ] ;
			
			! Product stock difference
			ProdStock( (fut,1) | DispFacHalfLife(fut) ) := InitialProdStock(fut) * 0.5^(2.5/(DispFacHalfLife(fut))) + 
				TotalSupply(fut,1) * PeriodLength(1) * CperUnit(fut) ;
			ProdStock( (fut,t) | t > 1 and DispFacHalfLife(fut) ) := ProdStock(fut,t-1) * 0.5^(PeriodLength(t-1)/(DispFacHalfLife(fut))) +
				TotalSupply(fut,t) * PeriodLength(t) * CperUnit(fut) ;
			DpProdDiffStock(t) := -( sum[ fut, ProdStock(fut,t+1) - ProdStock(fut,t) ] )/PeriodLength(t) ;
			
			! Product substitution
			DpSubProd(t) := - sum[ (fut), TotalSupply(fut,t) * CperUnit(fut) * DispFacProd(fut) ] ;
			
			! Product end of life
			DPSubEol(t) := - sum[ fut | DispFacHalfLife(fut), 
					ProdStock(fut,t) * ( 1- 0.5^(PeriodLength(t)/(DispFacHalfLife(fut)))  ) * DispFacEol(fut) ] /PeriodLength(t) ;
			
			! Total net carbon emissions
			NCE(t) := DpTreeDiffStock(t)
			+ DpSoilDiffSTock(t)
			+ DpProdDiffStock(t)
			+ DpSubProd(t)
			+ DPSubEol(t)
			+ DpOrganicSoil(t) ;
		}
	}
	Procedure SetSetAsides {
		Body: {
			for ia do
				CurrJ := First(j) ;
			if Age(ia,CurrJ,1) >= 100 then
				SetAsideIndex(ia) := 13.9*min(1,Dgv(ia,CurrJ,1)/40.) + 37.1*min(1,InitDeadAbove(ia)/20) ;
			elseif Age(ia,CurrJ,1) >= 70 then
				SetAsideIndex(ia) := 13.3*min(1,Dgv(ia,CurrJ,1)/40.) + 29.6*min(1,InitDeadAbove(ia)/20) ;
			elseif Age(ia,CurrJ,1) >= 40 then
				SetAsideIndex(ia) := 5.5*min(1,Dgv(ia,CurrJ,1)/40.) + 17.1*min(1,InitDeadAbove(ia)/20) ;
			else
				SetAsideIndex(ia) := 0 ;
			endif ;
			endfor ;
			
			empty ParTmp ;
			BestSetAsideIndex := sort( ia | SetAsideIndex(ia), - SetAsideIndex(ia) ) ;
			TotSetAsideArea := sum[ ia, Scale(ia) ] * SetasideRate - sum[ ia | hasSetAside(ia), Scale(ia) ];
			for ib | hasSetAside(ib) = 0 do
				hasSetAside(ib) := 1 ;
				ParTmp += Scale(ib) ;
				if ParTmp > TotSetAsideArea then
					break ;
				endif ;
			endfor ;
		}
	}
	Procedure SolveGMPrnd {
		Body: {
			!-- Solve with SuperFacilities
			TotalSupply.Lower( (fut,t) |  CommodityType(fut) = 'D' ) := q0(fut,t);
			ActiveFacility := SuperFacility ;
			NetOutputAtFacility.Lower( (fut,fa,t) | CommodityType( StringToElement(Factor,FactorForCapacity(CurrFT(fa))) ) = 'F' and t < LastPeriod  ) :=
				q0(StringToElement(Factor,FactorForCapacity(CurrFT(fa))),t) * InitialCapacity(fa) / 
				sum[ f | f in ActiveFacility and CurrFT(f) = CurrFT(fa), InitialCapacity(f) ];
			statusmessage('Solving: SuperFacilities' );
			solve MaxNetSurplus ;
			PutRegionResults;
			halt;
			
			! Generate with ordinary facilities
			ActiveFacility := Facility - SuperFacility ;
			NetOutputAtFacility.Lower( (fut,fa,t) | CommodityType( StringToElement(Factor,FactorForCapacity(CurrFT(fa))) ) = 'F' and t < LastPeriod  ) :=
				q0(StringToElement(Factor,FactorForCapacity(CurrFT(fa))),t) * InitialCapacity(fa) / 
				sum[ f | f in ActiveFacility and CurrFT(f) = CurrFT(fa), InitialCapacity(f) ];
			SweForGMP := GMP::Instance::Generate( MaxNetSurplus ) ;
			
			ParTmp := 1;
			ObjectiveValue := 0;
			iter1 := 1;
			SaveX(ia,j) := 0;
			while ParTmp > 1.e-5 do
				for (ia,j) | j in xToRun(ia) and x(ia,j) = 0 and SaveX(ia,j) = 0 do
					GMP::Column::SetUpperbound( SweForGMP, x(ia,j), 0 );
				endfor;
				SaveX( (ia,j) | x(ia,j) ) := 1;
				for (ia,j) | j in xToRun(ia) and SaveX(ia,j) = 0 and uniform(0,1) < 0.3 do
					GMP::Column::SetUpperbound( SweForGMP, x(ia,j), 1 );
				endfor;
				GMP::Instance::Solve( SweForGMP );
				statusmessage( iter1 + " " + GMP::Solution::GetObjective( SweForGMP, 1 ) );
				ParTmp := abs[ ( ObjectiveValue - MaxNetSurplus.Objective ) / ( ObjectiveValue + 1.e-4) ];
				ObjectiveValue := MaxNetSurplus.Objective;
				iter1 += 1;
			endwhile;
			CaseFileSave( "Solution2.data", SolutionIdentifiers ) ;
			PutRegionResults;
		}
	}
	Procedure SolveGMPrc {
		Body: {
			!-- Solve with SuperFacilities
			ActiveFacility := SuperFacility ;
			NetOutputAtFacility.Lower( (fut,fa,t) | CommodityType( StringToElement(Factor,FactorForCapacity(CurrFT(fa))) ) = 'F' and t < LastPeriod  ) :=
				q0(StringToElement(Factor,FactorForCapacity(CurrFT(fa))),t) * InitialCapacity(fa) / 
				sum[ f | f in ActiveFacility and CurrFT(f) = CurrFT(fa), InitialCapacity(f) ];
			statusmessage('Solving: SuperFacilities' );
			solve MaxNetSurplus ;
			if MaxNetSurplus.Objective = NA then
				dialogmessage('SuperFacilities failed!');
				halt;
			endif;
			
			!-- Generate with ordinary facilities
			statusmessage('Loading problem All facilities' );
			ActiveFacility := Facility - SuperFacility ;
			NetOutputAtFacility.Lower( (fut,fa,t) | CommodityType( StringToElement(Factor,FactorForCapacity(CurrFT(fa))) ) = 'F' and t < LastPeriod  ) :=
				q0(StringToElement(Factor,FactorForCapacity(CurrFT(fa))),t) * InitialCapacity(fa) / 
				sum[ f | f in ActiveFacility and CurrFT(f) = CurrFT(fa), InitialCapacity(f) ];
			SweForGMP := GMP::Instance::Generate( MaxNetSurplus ) ;
			
			SaveX(ia,j) := 0;
			for (ia,j) | j in xToRun(ia) and x(ia,j) = 0 and SaveX(ia,j) = 0 do
				GMP::Column::SetUpperbound( SweForGMP, x(ia,j), 0 );
			endfor;
			SaveX( (ia,j) | x(ia,j) ) := 1;
			for ia do
				CurrxToRun := NBest( j | j in xToRun(ia) and SaveX(ia,j) = 0 , x.ReducedCost(ia,j), 500 );
				for j | j in CurrxToRun do
					SaveX(ia,j) := 1;
					GMP::Column::SetUpperbound( SweForGMP, x(ia,j), 1 );
				endfor;
			endfor;
			
			!-- Solve reduced problem
			statusmessage('Solving All facilities' );
			GMP::Instance::Solve( SweForGMP );
			
			if MaxNetSurplus.Objective = NA then
				dialogmessage('No solution available!');
				halt;
			else
				CaseFileSave( "Solution2.data", SolutionIdentifiers ) ;
				PutRegionResults;
			endif;
		}
	}
	Procedure SolveGMP {
		Body: {
			TotalSupply.Lower( (fut,t) |  CommodityType(fut) = 'D' or CommodityType(fut) = 'F' ) := q0(fut,t);
			
			ActiveFacility := SuperFacility ;
			NetOutputAtFacility.Lower( (fut,fa,t) | CommodityType( StringToElement(Factor,FactorForCapacity(CurrFT(fa))) ) = 'F' and t < LastPeriod  ) :=
				q0(StringToElement(Factor,FactorForCapacity(CurrFT(fa))),t) * InitialCapacity(fa) / 
				sum[ f | f in ActiveFacility and CurrFT(f) = CurrFT(fa), InitialCapacity(f) ];
			
			statusmessage('Solving: SuperFacilities' );
			solve MaxNetSurplus ;
			empty SaveX;
			SaveX(ia,j) := x(ia,j);
			
			ActiveFacility := Facility - SuperFacility ;
			NetOutputAtFacility.Lower( (fut,fa,t) | CommodityType( StringToElement(Factor,FactorForCapacity(CurrFT(fa))) ) = 'F' and t < LastPeriod  ) :=
				q0(StringToElement(Factor,FactorForCapacity(CurrFT(fa))),t) * InitialCapacity(fa) / 
				sum[ f | f in ActiveFacility and CurrFT(f) = CurrFT(fa), InitialCapacity(f) ];
			
			x.Upper( (ia,j) | j in xToRun(ia) and x(ia,j) = 0) := 0;
			for ia do
				CurrJ := First( j | x(ia,j) > 0 );
				x(ia,Currj) := 1 - sum[ j | j in xToRun(ia) and not CurrJ, x(ia,j) ];
			endfor;
			solve MaxNetSurplus ;
			dialogmessage( MaxNetSurplus.Objective );
			
			InputAtFacility.Upper( (fin,fa,t) | RelevantInput(fin,fa) ) := InputAtFacility(fin,fa,t);
			InputAtFacility.Lower( (fin,fa,t) | RelevantInput(fin,fa) ) := InputAtFacility(fin,fa,t);
			x.Upper( (ia,j) | j in xToRun(ia) ) := 1;
			x.Lower( (ia,j) | j in xToRun(ia) ) := 0;
			solve MaxNetSurplus ;
			dialogmessage( MaxNetSurplus.Objective );
			
			InputAtFacility.Upper( (fin,fa,t) | RelevantInput(fin,fa) ) := 1e9;
			InputAtFacility.Lower( (fin,fa,t) | RelevantInput(fin,fa) ) := 0;
			x.Upper( (ia,j) | j in xToRun(ia) and x(ia,j) = 0) := 0;
			solve MaxNetSurplus ;
			dialogmessage( MaxNetSurplus.Objective );
			
			halt;	
			
			
			
			
			ParTmp := 1;
			ObjectiveValue := 0;
			iter1 := 1;
			while ParTmp > 1.e-4 do
			
				x.Upper( (ia,j) | j in xToRun(ia) ) := min[ 1, x(ia,j) + 1e-4 ];
				x.Lower( (ia,j) | j in xToRun(ia) ) := max[ 0, x(ia,j) - 1e-4 ];
				solve MaxNetSurplus ;
				statusmessage( MaxNetSurplus.Objective );
				InputAtFacility.Upper( (fin,fa,t) | RelevantInput(fin,fa) ) := InputAtFacility(fin,fa,t);
				InputAtFacility.Lower( (fin,fa,t) | RelevantInput(fin,fa) ) := InputAtFacility(fin,fa,t);
				x.Upper( (ia,j) | j in xToRun(ia) ) := 1;
				x.Lower( (ia,j) | j in xToRun(ia) ) := 0;
				solve MaxNetSurplus ;
				statusmessage( MaxNetSurplus.Objective );
				InputAtFacility.Upper( (fin,fa,t) | RelevantInput(fin,fa) ) := 1e9;
				InputAtFacility.Lower( (fin,fa,t) | RelevantInput(fin,fa) ) := 0;
				iter1 += 1;
				ParTmp := abs[ ( ObjectiveValue - MaxNetSurplus.Objective ) / ( ObjectiveValue + 1.e-4) ];
				ObjectiveValue := MaxNetSurplus.Objective;
			
			endwhile;
			PutRegionResults;
			halt;	
			
			statusmessage('Solving: all Facilities' );
			solve MaxNetSurplus ;
			halt;
			
			ActiveFacility := Facility - SuperFacility ;
			ForestCValuePerTonC := 1200;
			SweForGMP := GMP::Instance::Generate( MaxNetSurplus ) ;
			statusmessage( 'Solving: start' );
			GMP::Instance::Solve( SweForGMP );
			
			ForestCValuePerTonC := 1200;
			iter1 := 1;
			while iter1 < LastPeriod do
				for t | t <= iter1 do
					GMP::Coefficient::Set( SweForGMP, CValuePerT(t), DiffC(t), - ForestCValuePerTonC /PeriodLength(t) );
				endfor;
				statusmessage(iter1);
				GMP::Instance::Solve( SweForGMP ); 
				iter1 += 1;
			endwhile;
			halt;
			
				for (ia,j) | j in xToRun(ia) do
					GMP::Column::Freeze( SweForGMP, x(ia,j), SaveX(ia,j) );
				endfor;
				dialogmessage( GMP::Solution::GetObjective( SweForGMP, 1 ) );
			
			for (ia,j) | j in xToRun(ia) do
				GMP::Column::UnFreeze( SweForGMP, x(ia,j) );
			endfor;
			GMP::Instance::Solve( SweForGMP );
			dialogmessage( GMP::Solution::GetObjective( SweForGMP, 1 ) );
			halt;
			
			!-- Step 2: Solve with new parameter */
			ForestCValuePerTonC := 1200;
			for t | t < LastPeriod do
				GMP::Coefficient::Set( SweForGMP, CValuePerT(t), DiffC(t), - ForestCValuePerTonC /PeriodLength(t) );
			endfor;
			statusmessage('Solving: 1200');
			GMP::Instance::Solve( SweForGMP ); 
			ObjectiveValue := GMP::Solution::GetObjective( SweForGMP, 1 );
			dialogmessage( ObjectiveValue );
		}
	}
	Procedure SolveGMPredcost {
		Body: {
			!-- Set up problem
			empty x, x.ReducedCost, SaveRC;
			
			!-- Step 1: derive shadow prices to start with after running:
			!-- (i) w. SweForGMP, (ii) running with SweForGMP
			TotalSupply.Lower( (fut,t) |  CommodityType(fut) = 'D' or CommodityType(fut) = 'F' ) := q0(fut,t);
			ActiveFacility := Facility - SuperFacility ;
			statusmessage('Solving 1');
			SweForGMP := GMP::Instance::Generate( MaxNetSurplus, "MaxNetSurplus" ) ;
			
			!-- Step 2: 
			Iter1 := 0 ;
			RelativeImprovm := 1 ;
			while Iter1 < 5 do
				statusmessage("Solving with All facilities - limited x variables: " + Iter1);
				GMP::Instance::Solve( SweForGMP ); 
				ObjectiveValue := GMP::Solution::GetObjective( SweForGMP, 1 );
			!	dialogmessage( sum[ ia, Card(xToRun(ia)) ] + " " + sum[ ia, Card(CurrxToRun(ia)) ]  );
				dialogmessage( ObjectiveValue );
			/*	for ia | Card(xToRun(ia)) > Card(CurrxToRun(ia)) do
					CurrJ :=argmin[ j | j in xToRun(ia) and not j in CurrxToRun(ia), 
						sum[ (fin,t), Scale(ia) * Extraction(fin,ia,j,t) * PlotOutput(fin,ia,j,t) / PeriodLength(t) * (-ConHauling(fin,ia,t).ShadowPrice) ]
						+
						sum[ t, Scale(ia) * ( SCost(ia,j,t) + HCost(ia,j,t) )/ PeriodLength(t) * HarvestCost(t).ShadowPrice ]
						+
						sum[ t | OwnTyp(ia)="Private",  
							AmenityValuePerM3 * PeriodLength(t) / (1+exp(-0.05*(age(ia,j,t)-LSA(ia)))) * 
							m3Vol(ia,j,t) * Scale(ia) / PeriodLength(t) * AmenityPerT(t).ShadowPrice ] 
						-
						sum[ t | pA(ia,j) <= t and pB(ia,j) >= t, Test_AreaEq1(ia,t).ShadowPrice ]
						+
						sum[ t | t < LastPeriod and pB(ia,j) = t, (-Test_AreaFF(ia,t).ShadowPrice) ]
						+
						sum[ t | t < LastPeriod and pA(ia,j) = t+1, Test_AreaFF(ia,t).ShadowPrice ] 
						];
					CurrxToRun(ia) += CurrJ;
					GMP::Column::Add( SweForGMP, x(ia,CurrJ) );
					for (fin,t) | ExtractionRate(fin) do
						GMP::Coefficient::Set( SweForGMP, ConHauling(fin,ia,t), x(ia,CurrJ), 
							Scale(ia) * Extraction(fin,ia,CurrJ,t) * PlotOutput(fin,ia,CurrJ,t) / PeriodLength(t) );
					endfor;
					for t do
						GMP::Coefficient::Set( SweForGMP, HarvestCost(t), x(ia,CurrJ), 
							Scale(ia) * ( SCost(ia,CurrJ,t) + HCost(ia,CurrJ,t) )/ PeriodLength(t) );
					endfor;
					for t do
						if OwnTyp(ia)="Private" then
							GMP::Coefficient::Set( SweForGMP, AmenityPerT(t),x(ia,CurrJ),
							AmenityValuePerM3 * PeriodLength(t) / (1+exp(-0.05*(age(ia,CurrJ,t)-LSA(ia)))) * 
							m3Vol(ia,CurrJ,t) * Scale(ia) / PeriodLength(t) );
						endif;
					endfor;
					for t | pA(ia,CurrJ) <= t and pB(ia,CurrJ) >= t do
						GMP::Coefficient::Set( SweForGMP, Test_AreaEq1(ia,t), x(ia,CurrJ), 1 );
					endfor;
					for t | t < LastPeriod and pB(ia,CurrJ) = t do
						GMP::Coefficient::Set( SweForGMP, Test_AreaFF(ia,t), x(ia,CurrJ), 1 );
					endfor;
					for t | t < LastPeriod and pA(ia,CurrJ) = t+1 do
						GMP::Coefficient::Set( SweForGMP, Test_AreaFF(ia,t), x(ia,CurrJ), -1 );
					endfor; 
				endfor; */
			!	dialogmessage( sum[ ia, Card(xToRun(ia)) ] + " " + sum[ ia, Card(CurrxToRun(ia)) ]  );
				Iter1 += 1 ;
			endwhile ;
			
			halt;
			
			statusmessage("Initial Problem solves with FixedDemand for 4 periods");
			for (fut,t) | t <= 1 and CommodityType(fut) = 'D' or CommodityType(fut) = 'F' do
				GMP::Column::SetUpperBound( SweForGMP, TotalSupply(fut,t), q0(fut,t) );
				GMP::Column::SetLowerBound( SweForGMP, TotalSupply(fut,t), q0(fut,t) );
			endfor;
			halt; 
			
			FixedDemand(fut,t) := q0(fut,t);
			for (fut,t) | t <= 4 and fut = 'Heat__' or fut = 'BioFue' do
				GMP::Column::SetUpperBound( SweForGMP, TotalSupply(fut,t), 0 );
				GMP::Row::SetRightHandSide( SweForGMP, ConMinSupply(fut,t), FixedDemand(fut,t) );
				GMP::Column::SetUpperBound( SweForGMP, Export(fut,t), 0 );
			endfor;	
			/*SaveRC( (ia,j) | j in xToRun(ia) ) := x(ia,j).ReducedCost ;
			CurrxToRun(ia) := NBest( j | j in xToRun(ia), SaveRC(ia,j), 
				min[ 50, max[ Count( j | x(ia,j) > 0), Card(xToRun(ia)) ] ] );
			for (ia,j) | j in xToRun(ia) and not j in CurrxToRun(ia) do
				GMP::Column::SetUpperBound( SweForGMP, x(ia,j), 0 );
			endfor ; */
			statusmessage("Problem solved with FixedDemand = q0 and limited no. x");
			GMP::Instance::Solve( SweForGMP ); 
			halt;
			
			statusmessage("Problem solved with FixedDemand = q0 and fixed x");
			FixedDemand(fut,t) := q0(fut,t);
			for (fut,t) | fut = 'Heat__' or fut = 'BioFue' do
				GMP::Row::SetRightHandSide( SweForGMP, ConMinSupply(fut,t), 0 );
			endfor;	
			for (ia,j) | j in xToRun(ia) do
				ParTmp := x(ia,j);
				GMP::Column::SetUpperBound( SweForGMP, x(ia,j), ParTmp  ) ;
				GMP::Column::SetLowerBound( SweForGMP, x(ia,j), ParTmp  ) ;
			endfor;
			GMP::Instance::Solve( SweForGMP ); 
			halt;
			
			iter1 := 0;
			while iter1 < LastPeriod do
				empty SaveRC;
				SaveRC( (ia,j) | j in xToRun(ia) ) := x(ia,j).ReducedCost ;
				xToRun(ia) := NBest( j | j in xToRun(ia), SaveRC(ia,j), 
					min[ 200, max[ Count( j | x(ia,j) > 0), 0.9*Card(xToRun(ia)) ] ] );
				/*for (ia,j) | j in CurrxToRun(ia) and not j in xToRun(ia) do
					GMP::Column::SetUpperBound( SweForGMP, x(ia,j), 0 );
				endfor ;
				CurrxToRun(ia) := xToRun(ia); */
			!	dialogmessage( " No. active x: " + sum[ ia, Card(xToRun(ia)) ] ); 
				iter1 += 4;
				for t | t <= iter1 do
					FixedDemand( (fut,t) | CommodityType(fut) = 'D' or CommodityType(fut) = 'F' ) 
						:= q0(fut,t);
					for fut | CommodityType(fut) = 'D' or CommodityType(fut) = 'F' do
						GMP::Row::SetRightHandSide( SweForGMP,
							Export(fut,t), -FixedDemand(fut,t) );	
					endfor;
				endfor; 
				statusmessage("t = " + iter1);
				GMP::Instance::Solve( SweForGMP ); 
			endwhile; 
			
			!!-- Select initial variable and solve
			!for ia | PlotToRunx(ia) do ! Find variable with max NPV
			!	for j | j in xToRun(ia) do
			!		if Uniform(0,1) < 0.9 then GMP::Column::SetUpperBound( SweForGMP, x(ia,j), 0  ) ; endif ;
			!	endfor ;
			!!	RCvalue(j) := -1.e6 ;
			!!	RCvalue( (j) | xToRun(ia,j)) := sum[ t, df(t) * ( sum[ fin, PlotOutput(fin,i,j,t) ] * p0(t,'sawnwd') - Cost0(ia,j,t) ) ] ;
			!!	CurrJ := argmax[ j, RCvalue(j) ] ;
			!!	for j | GMP::Column::SetUpperBound( SweForGMP, x(ia,CurrJ), 1  ) ;
			!endfor ;
			!
			!Iter1 := 0 ;
			!RelativeImprovm := 1 ;
			!while RelativeImprovm > 0.01 do
			!	GMP::Instance::Solve( SweForGMP );
			!	for (ia,j) | xToRun(ia,j) do
			!		GMP::Column::SetUpperBound( SweForGMP, x(ia,j), 0  ) ;
			!	endfor ;
			!	RelativeImprovm := 0 ;
			!	for i | PlotToRunx(i) do
			!		CurrJ := argmax[ j | j in xToRun(i), x(ia,j).ReducedCost ] ;
			!		GMP::Column::SetUpperBound( SweForGMP, x(ia,CurrJ), 1  ) ;
			!		RelativeImprovm += x(ia,CurrJ).ReducedCost ;
			!	endfor ;
			!	RelativeImprovm := RelativeImprovm / GMP::Solution::GetObjective( SweForGMP, 1 ) ;
			!	Iter1 += 1 ;
			!	statusmessage( GMP::Solution::GetObjective( SweForGMP, 1 ) + " " + RelativeImprovm + " " + Iter1 ) ;
			!endwhile ;
			!
			!PutResults ;
			!
			!endif ;
			!
		}
	}
	Procedure PutIndOutput {
		Body: {
			OutputFileResults := FileNames('IndOutput');
			ResultFile.PageWidth := 600 ;
			PUT ResultFile ;
			
			PUT "Facility", @13, "Process", @24, "Output", @30 ; for t do PUT t: >10:0; endfor ; PUT / ;
			for (fut,fa) do
			 	PeriodResult(t) := NetOutputAtFacility(fut,fa,t) + sum[ f2 | f2 in ActiveFacility, FacilityToFacility(fut,fa,f2,t) ] ;
				if sum[ t | t < LastPeriod, PeriodResult(t) ] > 0 then
					PUT fa, @14, CurrFT(fa), @20, fut:>10:0; for t | t < LastPeriod do PUT PeriodResult(t): >10:0; endfor ; PUT / ; 
				endif ;
			endfor ;
			
			putclose ResultFile ;
		}
	}
	Procedure PutBirchSawMillAnalysisData {
		Body: {
			OutputFileResults := FileNames('BirchSawmillOutput') ;
			ResultFile.PageWidth := 600 ;
			PUT ResultFile ;
			
			for fa | FacilityType(fa) = "sawmbe" do
				put fa: >10:2;
				put NetOutputAtFacility('Sawnbe',fa,1): >10:0 ;
				put sum[ ia | KmPlotToLoc(ia,CurrFacInLoc(fa)) < 100, 
					max( (j) | j in xToRun(ia), PlotOutput('BerTim',ia,j,1) ) * Scale(ia) ]*0.2: >10:0;
				put sum[ ia | KmPlotToLoc(ia,CurrFacInLoc(fa)) < 200, 
					max( (j) | j in xToRun(ia), PlotOutput('BerTim',ia,j,1) ) * Scale(ia) ]*0.2: >10:0;
				put sum[ ia | KmPlotToLoc(ia,CurrFacInLoc(fa)) < 300, 
					max( (j) | j in xToRun(ia), PlotOutput('BerTim',ia,j,1) ) * Scale(ia) ]*0.2: >10:0;
				ParTmp := sum[ ia | KmPlotToLoc(ia,CurrFacInLoc(fa)) < 300, 
					max( (j) | j in xToRun(ia), PlotOutput('BerTim',ia,j,1) ) * 
					Scale(ia) * KmPlotToLoc(ia,CurrFacInLoc(fa))] ;
				ParTmp2 := Power( sum[ ia | KmPlotToLoc(ia,CurrFacInLoc(fa)) < 300, 
					max( (j) | j in xToRun(ia), PlotOutput('BerTim',ia,j,1) ) * 
					Scale(ia) ] + 0.001,-1 );
				put ParTmp * ParTmp2: >10:2;
				put min( f | FacilityType(f) = 'PuChem' or FacilityType(f) = 'PuDiss' or FacilityType(f) = 'PuCTMP', 
					KmLocToLoc(CurrFacInLoc(fa),CurrFacInLoc(f)) ): >10:2;
			
			PUT / ;  
			
			endfor;
			
			PUT / ;  
			PUT/, "Period" ,  @30; for t do PUT t: >10:0; endfor ; PUT / ; 
			
			PUT "Lövmassa till massaindustrin" ,  @30; 
				for t do PUT sum( ft, FAToUse('Decids',ft,1,t)) * 1.e-6: >10:3; endfor ; PUT / ;
			PUT "Bjorksågtimmer till massaindustrin" ,  @30; 
				for t do PUT sum( ft | ft = 'PuChem' or ft = 'PuDiss' or ft = 'PuCTMP', 
					FAToUse('BerTim',ft,1,t)) * 1.e-6: >10:3; endfor ; PUT / ;
			PUT "Bjorksågtimmer till sågverken" ,  @30; 
				for t do PUT FAToUse('BerTim','Sawmbe',1,t) * 1.e-6: >10:3; endfor ; PUT / ;
			PUT "Hybridtimmer till sågverken" ,  @30; 
				for t do 
					PUT sum[ (ia,j) | t >= pA(ia,j) and t <= pB(ia,j) and 
					count( t1 | t1 >= pA(ia,j) and t1 <= pB(ia,j) and Nratg(ia,j,t1) >= 8 and Nratg(ia,j,t1) <= 11) > 0,
					Scale(ia) * PlotOutput('BerTim',ia,j,t) * x(ia,j) ]  * 1.e-6 *0.2: >10:3; 
				endfor ; PUT / ;
			PUT "Hybridmassaved till massaverk" ,  @30; 
				for t do 
					PUT sum[ (ia,j) | t >= pA(ia,j) and t <= pB(ia,j) and 
					count( t1 | t1 >= pA(ia,j) and t1 <= pB(ia,j) and Nratg(ia,j,t1) >= 8 and Nratg(ia,j,t1) <= 11) > 0,
					Scale(ia) * PlotOutput('Decids',ia,j,t) * x(ia,j) *0.2]  * 1.e-6: >10:3; 
				endfor ; PUT / ;
			PUT "Föryngring med hybrid (ha)" ,  @30; 
				for t do 
					PUT sum[ (ia,j) | t >= pA(ia,j) and t <= pB(ia,j) and Nratg(ia,j,t) >= 8 and Nratg(ia,j,t) <= 11,
					Scale(ia) * x(ia,j) ] *0.2  : >10:0; 
				endfor ; PUT / ;
			
			PUT / ;  
			
			PUT/, "Period" ,  @30; for t do put t: >10:0; endfor ; PUT / ;
			empty TableDA;
			for (ia,j,t) | x(ia,j) do
				DiaTab := max(1,round((min(40,Dgv(ia,j,t))-12)/2) + 1);
				AgeTab := max(1,round((min(130,Age(ia,j,t))-30)/10) + 1);
				TableDA(DiaTab,AgeTab,t) += Scale(ia) * PlotOutput('BerTim',ia,j,t) * x(ia,j) * 0.2;
			endfor;
			for (ac,dc) do
				PUT "Age " + (ac*10+20) + "-" + (ac*10+30) + " Dia "  + (dc*2+8) + "-" + (dc*2+10) + ":",  @30; 
				for t do PUT TableDA(dc,ac,t): >10:0; endfor; PUT / ;  
			endfor;
			
			putclose ResultFile ;
		}
	}
	Procedure PutPayArticleResults {
		Body: {
			OutputFileResults := "PayArticleOutput.txt" ;
			ResultFile.PageWidth := 600 ;
			PUT ResultFile ;
			
			
			/*
			PUT "Period" ,  @30; for t do PUT t: >10:0; endfor ; PUT / ; 
			
			PUT "------------------------------------AllForest------------------------------------" ; PUT / ;
			
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) >= 0, 
				Scale(ia) * Dgv(ia,j,t) * m3Vol(ia,j,t) * x(ia,j) ] ;
			PUT "Diameter" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1):>10:1; endfor ; PUT / ;
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) >= 0, 
				Scale(ia) * m3Dec(ia,j,t) * x(ia,j) ] ;
			PUT "Deciduous(%)" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1)*100:>10:0; endfor ; PUT / ;
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) >= 0, 
				Scale(ia) * Age(ia,j,t) * m3Vol(ia,j,t) * x(ia,j) ] ;
			PUT "Age" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1):>10:1; endfor ; PUT / ;
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) >= 0, 
				Scale(ia) * M3skMort(ia,j,t) * x(ia,j) ] ;
			PUT "Mortality(m3/ha)" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1):>10:1; endfor ; PUT / ;
			PUT "Hectares" ,  @30; PUT Test(1):>10:1; PUT / ;
			
			PUT "------------------------------------NoManagement------------------------------------" ; PUT / ;
			
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) = 1, 
				Scale(ia) * Dgv(ia,j,t) * m3Vol(ia,j,t) * x(ia,j) ] ;
			PUT "Diameter" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1):>10:1; endfor ; PUT / ;
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) = 1, 
				Scale(ia) * m3Dec(ia,j,t) * x(ia,j) ] ;
			PUT "Deciduous(%)" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1)*100:>10:0; endfor ; PUT / ;
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) = 1, 
				Scale(ia) * Age(ia,j,t) * x(ia,j) ] ;
			PUT "Age" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1):>10:1; endfor ; PUT / ;
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) = 1, 
				Scale(ia) * M3skMort(ia,j,t) * x(ia,j) ] ;
			PUT "Mortality(m3/ha)" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1):>10:1; endfor ; PUT / ;
			PUT "Hectares" ,  @30; PUT Test(1):>10:1; PUT / ;
			
			
			PUT "------------------------------------Managed------------------------------------" ; PUT / ;
			
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia)  <> 1, 
				Scale(ia) * Dgv(ia,j,t) * m3Vol(ia,j,t) * x(ia,j) ] ;
			PUT "Diameter" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1):>10:1; endfor ; PUT / ;
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia)  <> 1, 
				Scale(ia) * m3Dec(ia,j,t) * x(ia,j) ] ;
			PUT "Deciduous(%)" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1)*100:>10:0; endfor ; PUT / ;
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) <> 1, 
				Scale(ia) * Age(ia,j,t) * m3Vol(ia,j,t) * x(ia,j) ] ;
			PUT "Age" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1):>10:1; endfor ; PUT / ;
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) <> 1, 
				Scale(ia) * M3skMort(ia,j,t) * x(ia,j) ] ;
			PUT "Mortality(m3/ha)" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1):>10:1; endfor ; PUT / ;
			PUT "Hectares" ,  @30; PUT Test(1):>10:1; PUT / ;
			
			PUT "------------------------------------SA_Pay------------------------------------" ; PUT / ;
			
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) = 0 and count( t1 | t1 <= 6, Treat0(ia,j,t1) > 1 ) = 0 and SetAsideIndex(ia),
				Scale(ia) * Dgv(ia,j,t) * m3Vol(ia,j,t) * x(ia,j) ] ;
			PUT "Diameter" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1):>10:1; endfor ; PUT / ;
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) = 0 and count( t1 | t1 <= 6, Treat0(ia,j,t1) > 1 ) = 0 and SetAsideIndex(ia),
				Scale(ia) * m3Dec(ia,j,t) * x(ia,j) ] ;
			PUT "Deciduous(%)" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1)*100:>10:0; endfor ; PUT / ;
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) = 0 and count( t1 | t1 <= 6, Treat0(ia,j,t1) > 1 ) = 0 and SetAsideIndex(ia),
				Scale(ia) * Age(ia,j,t) * m3Vol(ia,j,t) * x(ia,j) ] ;
			PUT "Age" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1):>10:1; endfor ; PUT / ;
			PutPeriod(t) := sum[ (ia,j) | j in xToRun(ia) and hasSetAside(ia) = 0 and count( t1 | t1 <= 6, Treat0(ia,j,t1) > 1 ) = 0 and SetAsideIndex(ia),
				Scale(ia) * M3skMort(ia,j,t) * x(ia,j) ] ;
			PUT "Mortality(m3/ha)" ,  @30; for t do; PUT PutPeriod(t)*Test(t)^(-1):>10:1; endfor ; PUT / ;
			PUT "Hectares" ,  @30; PUT Test(1):>10:1; PUT / ;
			
			putclose ResultFile ;
			*/
		}
	}
